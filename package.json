{
  "name": "ore-supply-farmer-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "tsx src/app/cli/main.ts start",
    "dev": "tsx watch src/app/cli/main.ts start",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.7.5",
    "eslint": "^9.12.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "tsx": "^4.19.0",
    "vitest": "^2.1.4"
  }
}
